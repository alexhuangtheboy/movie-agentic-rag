# DashScope OpenAI-compatible LLM
LLM_MODEL=qwen-plus
LLM_ENDPOINT=https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-with-your-dashscope-api-key

# DashScope OpenAI-compatible embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_ENDPOINT=https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=replace-with-your-dashscope-api-key

# SQL Supabase: movie structured tables, memory, and LangGraph checkpoints
MOVIE_SQL_DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres
CHECKPOINT_DATABASE_URL=postgresql://user:password@host:5432/postgres
MEMORY_DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres

# Vector Supabase: movie_plot_embeddings pgvector table
MOVIE_VECTOR_DB_HOST=replace-with-vector-db-host
MOVIE_VECTOR_DB_PORT=5432
MOVIE_VECTOR_DB_USER=replace-with-vector-db-user
MOVIE_VECTOR_DB_PW=replace-with-vector-db-password
MOVIE_VECTOR_DB_NAME=postgres
MOVIE_VECTOR_TABLE=movie_plot_embeddings

# Neo4j movie graph
NEO4J_URL=neo4j+s://replace-with-instance.databases.neo4j.io
NEO4J_USERNAME=replace-with-username
NEO4J_PASSWORD=replace-with-password
NEO4J_DATABASE=neo4j

# Optional webhook for /movie/query stream mode
WEBHOOK_URL=

# Optional runtime behavior
# Set true in local development to create memory tables at startup.
# In production, prefer running database/init_memory.sql as a migration and keep this false.
MEMORY_AUTO_CREATE_TABLES=false
APP_FAIL_FAST_ON_STARTUP=false
USER_MEMORY_MAX_ITEMS=200
SESSION_MEMORY_MAX_ITEMS=100
ASCII_SANITIZE_ANSWERS=false
